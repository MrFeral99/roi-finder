generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  image           String?
  password        String?
  trialEndsAt     DateTime?
  preferences     UserPreferences?
  savedProperties SavedProperty[]
  myProperties    UserProperty[]
  feedback        UserFeedback?
  createdAt       DateTime          @default(now())
}

model UserProperty {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])

  title            String
  city             String
  address          String?
  price            Float
  sqm              Float
  monthlyRent      Float
  status           String   @default("valutazione") // "valutazione" | "acquistato" | "scartato"
  purchaseDate     String?
  acquisitionCosts Float?
  notes            String?
  vacancyRate      Float    @default(8)
  maintenanceRate  Float    @default(10)
  annualCondoFees  Float    @default(0)
  rentalMode            String   @default("monthly")
  weeklyRates           Json?
  mortgageAmount        Float?
  mortgageRate          Float?
  mortgageDurationYears Int?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserFeedback {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  score        Int
  priceRange   String
  improvements String?
  createdAt    DateTime @default(now())
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  city      String?
  minBudget Int?
  maxBudget Int?
  strategy  String?
  createdAt DateTime @default(now())
}

model WaitlistUser {
  id        String   @id @default(uuid())
  email     String   @unique
  city      String?
  createdAt DateTime @default(now())
}

model Property {
  id          String   @id @default(uuid())
  title       String
  city        String
  address     String
  price       Float
  sqm         Float
  sourceUrl   String
  sourceSite  String
  isAuction   Boolean  @default(false)
  auctionDate String?
  createdAt   DateTime @default(now())
}
